# Project-03 Environment Template
# Copy this to .env and fill in actual values for your environment

# Environment: development, staging, or production
NODE_ENV=development

# API Configuration
API_PORT=3000
API_HOST=localhost
CORS_ORIGIN=http://localhost:4200,http://localhost:4201

# Database Configuration
# For development: Set to "memory" or "sqlite"
# For production: Set to "postgres"
DB_TYPE=memory

# PostgreSQL Configuration (only needed if DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=project03_dev
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Optional: Full PostgreSQL connection string
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project03_dev

# Logging
LOG_LEVEL=debug

# Security
JWT_SECRET=your-super-secret-key-change-in-production
